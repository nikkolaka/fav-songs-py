# Spotify application credentials
CLIENT_ID=
CLIENT_SECRET=

# Must exactly match the redirect URI configured in Spotify
# Example: http://server.local:8090/api/auth/callback
REDIRECT_URI=

# Optional overrides
SPOTIFY_SCOPE=user-read-playback-state,user-read-currently-playing,playlist-modify-public,playlist-modify-private
DEFAULT_PLAYLIST_NAME=Favourite Songs - Whatsit

# Host port mapped to the container
APP_PORT=8090
